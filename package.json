{
    "name":  "hx-mm-logistics-system",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
                    "dev:backend":  "nodemon backend/index.js",
                    "dev:frontend":  "node scripts/dev-client.js",
                    "start":  "node backend/index.js",
                    "build":  "vite build frontend --outDir ../dist --emptyOutDir",
                    "preview":  "vite preview --host 0.0.0.0",
                    "db:create":  "node scripts/create-db.js",
                    "db:schema":  "node scripts/run-sql.js database/schema.sql",
                    "db:migrate":  "node scripts/run-sql.js database/migrations/001_production_safety.sql",
                    "db:migrate:auth":  "node scripts/run-sql.js database/migrations/002_auth_and_logs.sql",
                    "db:migrate:tracking":  "node scripts/run-sql.js database/migrations/003_tracking_query_and_inbound.sql",
                    "db:migrate:tracking-events":  "node scripts/run-sql.js database/migrations/004_tracking_events_core.sql",
                    "db:seed":  "node scripts/run-sql.js database/seed.sql",
                    "db:seed:users":  "node scripts/run-sql.js database/seed-users.sql",
                    "db:migrate:phase1b":  "node scripts/run-sql.js database/migrations/005_phase1b_tracking_events_contract.sql",
                    "db:migrate:batches":  "node scripts/run-sql.js database/migrations/007_phase2_batches.sql",
                    "db:migrate:exceptions":  "node scripts/run-sql.js database/migrations/008_phase3_exceptions.sql",
                    "db:migrate:phase1f":  "node scripts/run-sql.js database/migrations/006_phase1f_drop_shipment_events.sql",
                    "db:migrate:all":  "npm run db:migrate \u0026\u0026 npm run db:migrate:auth \u0026\u0026 npm run db:migrate:tracking \u0026\u0026 npm run db:migrate:tracking-events \u0026\u0026 npm run db:migrate:phase1b \u0026\u0026 npm run db:migrate:phase1f \u0026\u0026 npm run db:migrate:batches \u0026\u0026 npm run db:migrate:exceptions",
                    "db:init":  "npm run db:schema \u0026\u0026 npm run db:migrate:all \u0026\u0026 npm run db:seed \u0026\u0026 npm run db:seed:users",
                    "acceptance":  "node scripts/acceptance/run-acceptance.js"
                },
    "dependencies":  {
                         "@vitejs/plugin-react":  "^4.2.1",
                         "axios":  "^1.16.1",
                         "bcryptjs":  "^3.0.3",
                         "concurrently":  "^8.2.2",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.4.5",
                         "express":  "^4.18.3",
                         "html5-qrcode":  "^2.3.8",
                         "i18next":  "^26.2.0",
                         "jsonwebtoken":  "^9.0.3",
                         "pg":  "^8.11.3",
                         "react":  "^18.2.0",
                         "react-dom":  "^18.2.0",
                         "react-i18next":  "^17.0.8",
                         "vite":  "^5.1.6"
                     },
    "devDependencies":  {
                            "nodemon":  "^3.1.0"
                        }
}
