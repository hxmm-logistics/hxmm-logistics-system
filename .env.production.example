NODE_ENV=production
PORT=4000

POSTGRES_DB=hx_mm_logistics
POSTGRES_USER=hxmm
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgres://hxmm:replace-with-strong-postgres-password@127.0.0.1:5432/hx_mm_logistics

JWT_SECRET=replace-with-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h
CORS_ORIGIN=https://example.com

VITE_API_BASE_URL=/api

LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300

CHINA_SYNC_ENABLED=false
CHINA_SYNC_INTERVAL_MS=300000

BACKUP_DIR=/var/backups/hxmm-postgres
RETENTION_DAYS=7