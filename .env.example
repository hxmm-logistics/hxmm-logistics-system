# HX MM production/runtime config
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/hx_mm_logistics
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173

# Optional frontend/dev config
VITE_API_BASE_URL=/api
VITE_DEV_PORT=5173
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:4000

# Optional rate limits
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300

# Optional China logistics sync
CHINA_SYNC_ENABLED=false
CHINA_SYNC_INTERVAL_MS=300000
